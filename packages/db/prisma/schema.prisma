// Edubeam LMS core data model.
// Local dev uses SQLite for zero-setup; production switches `provider` to
// "postgresql" and sets DATABASE_URL accordingly. The schema avoids enums and
// arrays so it is portable across both providers (enum values are documented
// inline and validated in application code / packages/shared).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── School hierarchy ────────────────────────────────────────────────────────

model Tenant {
  id            String        @id @default(cuid())
  name          String
  code          String        @unique // e.g. "UK" (Uttarakhand)
  createdAt     DateTime      @default(now())
  districts     District[]
  users         User[]
  academicYears AcademicYear[]
  subjects      Subject[]
}

model District {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  name     String
  blocks   Block[]
  users    User[]

  @@unique([tenantId, name])
}

model Block {
  id         String   @id @default(cuid())
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  name       String
  schools    School[]
  users      User[]

  @@unique([districtId, name])
}

model School {
  id                  String         @id @default(cuid())
  blockId             String
  block               Block          @relation(fields: [blockId], references: [id])
  name                String
  udiseCode           String         @unique
  siteCode            String? // Virtual Classroom install code, e.g. VVEAMO352
  type                String? // GIC | GGIC | other (derived from name)
  hasVirtualClassroom Boolean        @default(false)
  hasIctLab           Boolean        @default(false)
  address             String?
  principalName       String?
  phone               String?
  phone2              String?
  // ── Infrastructure ─────────────────────────────────────────────────────────
  campusArea          Float?   // acres / sq-m (free text unit stored separately)
  campusAreaUnit      String?  // "acres" | "sqm"
  builtUpArea         Float?
  numBuildings        Int?
  numClassrooms       Int?
  hasPlayground       Boolean?
  hasBoundaryWall     Boolean?
  hasLibrary          Boolean?
  hasLaboratory       Boolean?
  hasComputerLab      Boolean?
  hasSmartClassroom   Boolean?
  hasElectricity      Boolean?
  hasInternet         Boolean?
  hasCctv             Boolean?

  // ── Water & Sanitation ───────────────────────────────────────────────────
  hasDrinkingWater    Boolean?
  drinkingWaterSource String?  // Tap | Hand-pump | Well | Tank | Other
  numToilets          Int?
  numBoysToilets      Int?
  numGirlsToilets     Int?
  hasCwsnToilet       Boolean?
  hasHandwashing      Boolean?

  // ── Academic ─────────────────────────────────────────────────────────────
  classesFrom         Int?     // lowest grade e.g. 1 (Pre-Primary) or 6
  classesTo           Int?     // highest grade e.g. 12
  streams             String?  // comma-separated: Science,Arts,Commerce

  // ── Safety & Security ────────────────────────────────────────────────────
  hasFireSafety       Boolean?
  hasDisasterPlan     Boolean?
  hasFirstAid         Boolean?
  hasSecurityGuard    Boolean?
  emergencyContact    String?

  // ── General Info (extended) ──────────────────────────────────────────────────
  registrationNumber  String?
  email               String?
  yearEstablished     Int?
  assemblyConstituency String?
  gramPanchayat       String?
  managedBy           String?  // "Govt" | "Private" | "Aided" | "Unaided" | "Other"
  mediumOfInstruction String?  // "Hindi" | "English" | "Bilingual" | "Other"

  // ── Land Record ────────────────────────────────────────────────────────────────
  totalLand           Float?
  totalLandUnit       String?  // "acres" | "sqm" | "sqft"
  hasGarden           Boolean?
  landInSchoolName    Boolean?

  // ── Building ───────────────────────────────────────────────────────────────────
  buildingType        String?  // "Pucca" | "Semi-Pucca" | "Kuchcha" | "Rented"
  hasHmRoom           Boolean?
  hasOfficeRoom       Boolean?
  hasCommonRoom       Boolean?
  hasComputerRoom     Boolean?
  hasArtCraftRoom     Boolean?

  // ── Furniture (per room: chairs / tables / cupboards) ─────────────────────────
  hmChairs            Int?
  hmTables            Int?
  hmCupboards         Int?
  officeChairs        Int?
  officeTables        Int?
  officeCupboards     Int?
  commonChairs        Int?
  commonTables        Int?
  commonCupboards     Int?
  classChairs         Int?
  classTables         Int?
  classCupboards      Int?
  computerChairs      Int?
  computerTables      Int?
  computerCupboards   Int?
  libraryChairs       Int?
  libraryTables       Int?
  libraryCupboards    Int?
  artChairs           Int?
  artTables           Int?
  artCupboards        Int?
  vcChairs            Int?
  vcTables            Int?
  vcCupboards         Int?

  // ── Water (additional) ────────────────────────────────────────────────────────
  hasOverheadTank     Boolean?
  waterQuantity       Float?   // litres per day
  hasWaterPurifier    Boolean?
  purifierInstallDate String?  // ISO date "YYYY-MM-DD"

  // ── Toilets (detailed counts) ──────────────────────────────────────────────────
  numUsableToilets    Int?
  numUnusableToilets  Int?
  numStaffToilets     Int?
  numCwsnToilets      Int?
  numOtherToilets     Int?

  // ── Electricity ────────────────────────────────────────────────────────────────
  electricityAvailability String?  // "24hrs" | "Partial" | "Solar" | "None"

  // ── Computer Lab ──────────────────────────────────────────────────────────────
  numDesktopPCs       Int?
  hasUPS              Boolean?
  hasInternetConnectivity Boolean?

  // ── Hostel ─────────────────────────────────────────────────────────────────────
  numHostelStudentRooms   Int?
  hostelStudentCapacity   Int?
  numHostelStudents       Int?
  numHostelStaffRooms     Int?
  hostelStaffCapacity     Int?

  //

  // ── Profile tracking ─────────────────────────────────────────────────────
  profileUpdatedBy    String?
  profileUpdatedAt    DateTime?

  enrollments         Enrollment[]
  boardResults        BoardResult[]
  yearlyResults       YearlyResult[]
  ictDeployment       IctDeployment?
  users               User[]
  students            Student[]
  staff               Staff[]
  quizzes             Quiz[]
  notices             Notice[]
  classSections       ClassSection[]
}

// ── Operational / analytics data (seeded from Excel) ────────────────────────

model Enrollment {
  id           String @id @default(cuid())
  schoolId     String
  school       School @relation(fields: [schoolId], references: [id])
  academicYear String // e.g. "2025-26"
  grade        Int // 6..12
  boys         Int    @default(0)
  girls        Int    @default(0)
  total        Int    @default(0)

  @@unique([schoolId, academicYear, grade])
}

model BoardResult {
  id           String @id @default(cuid())
  schoolId     String
  school       School @relation(fields: [schoolId], references: [id])
  examType     String // "10TH" | "12TH"
  subject      String // Hindi, English, Science, Math, Physics, ...
  passPct      Float // 0..1
  academicYear String

  @@unique([schoolId, examType, subject, academicYear])
}

// Historical board results, one row per school / year / exam (from the 5-year
// dataset). Powers real year-over-year improvement trends.
model YearlyResult {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])
  year     Int // e.g. 2020..2025
  examType String // "10TH" | "12TH"
  passPct  Float // 0..1 (Total %)

  @@unique([schoolId, year, examType])
}

model IctDeployment {
  id              String  @id @default(cuid())
  schoolId        String  @unique
  school          School  @relation(fields: [schoolId], references: [id])
  teacherCount    Int     @default(0)
  studentCount    Int     @default(0)
  academicYear    String
  lanIp           String?
  subnetMask      String?
  iduSerialNo     String?
  newIduSerialNo  String?
  iduModel        String?
  materialStatus  String?
  installRemark   String?
  engineerName    String?
  scheduledDate   String?
  certUpdate      String?
}

// ── Student & Staff registry (tender §6.2.6.5/6, §6.2.8.2-9) ─────────────────

// A pupil enrolled at a school. Captures the personal, guardian, RTE/category,
// bank and dropout details the tender's Government Dashboard & School Management
// System require. gender: "M" | "F" | "O". category: "GEN" | "OBC" | "SC" | "ST".
model Student {
  id             String   @id @default(cuid())
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id])
  admissionNo    String? // school admission number
  rollNo         String?
  name           String
  gender         String   @default("M") // M | F | O
  dateOfBirth    DateTime?
  grade          Int // class 1..12
  section        String? // A | B | ...
  guardianName   String?
  guardianPhone  String?
  guardianRelation String? // Father | Mother | Guardian
  address        String?
  category       String   @default("GEN") // GEN | OBC | SC | ST
  religion       String? // Hindu | Muslim | Sikh | Christian | Other
  isRte          Boolean  @default(false) // admitted under Right to Education
  bankAccount    String?
  healthNotes    String?
  isDropout      Boolean  @default(false)
  dropoutReason  String?
  academicYear   String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  // ── Extended profile ─────────────────────────────────────────────────────
  // Basic Info extras
  firstName        String?
  middleName       String?
  lastName         String?
  bloodGroup       String?  // A+ | A- | B+ | B- | AB+ | AB- | O+ | O-
  aadhaarNo        String?
  nationality      String?
  motherTongue     String?
  photoUrl         String?
  admissionDate    DateTime?
  admissionClass   Int?
  house            String?  // house / group
  admissionType    String?  // New | Transfer

  // Family Details
  fatherName       String?
  fatherPhone      String?
  fatherOccupation String?
  fatherEducation  String?
  motherName       String?
  motherPhone      String?
  motherOccupation String?
  motherEducation  String?

  // Address
  stateAddr          String?
  districtAddr       String?
  blockAddr          String?
  village            String?
  permanentAddress   String?
  correspondenceAddress String?
  pinCode            String?

  // Academic
  previousSchool   String?
  previousClass    Int?
  tcNumber         String?
  medium           String?  // Medium of Instruction
  subjectsOpted    String?  // comma-separated
  promotionStatus  String?  // Promoted | Detained | Passed Out
  cgpa             Float?

  // Health
  height           Float?   // cm
  weight           Float?   // kg
  cwsnStatus       Boolean?
  vaccinationStatus String?
  healthCheckupDate DateTime?

  // Hostel
  hostelRequired   Boolean?
  hostelName       String?
  roomNumber       String?
  hostelFeeStatus  String?  // Paid | Pending | Waived

  // Documents (store reference notes, not binary files)
  docAadhaar       String?
  docBirthCert     String?
  docTc            String?
  docCaste         String?
  docIncome        String?
  docResidence     String?
  docPhoto         String?
  docMedical       String?
  docOther         String?

  // Profile tracking
  profileUpdatedBy String?
  profileUpdatedAt DateTime?

  @@index([schoolId, grade])
}

// A teacher / faculty / lab-assistant / principal at a school. staffType:
// "TEACHER" | "FACULTY" | "LAB_ASSISTANT" | "PRINCIPAL".
model Staff {
  id             String   @id @default(cuid())
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id])
  employeeId     String?
  name           String
  gender         String   @default("M")
  dateOfBirth    DateTime?
  staffType      String   @default("TEACHER")
  designation    String?
  qualification  String? // highest qualification, e.g. M.Sc, B.Ed
  subjects       String? // comma-separated subjects taught
  phone          String?
  email          String?
  department     String?
  salaryGroup    String? // pay band / level
  joiningDate    DateTime?
  isClassTeacher Boolean  @default(false)
  classTeacherOf String? // e.g. "8-A"
  active         Boolean  @default(true)
  academicYear   String
  createdAt      DateTime @default(now())

  @@index([schoolId, staffType])
}

// ── Users & RBAC ────────────────────────────────────────────────────────────

// role: ADMIN | STATE_OFFICIAL | DISTRICT_OFFICIAL | BLOCK_OFFICIAL | PRINCIPAL | TEACHER | STUDENT | PARENT
// Scope is enforced in app code: STATE_OFFICIAL -> tenant-wide, DISTRICT_OFFICIAL -> districtId,
// BLOCK_OFFICIAL -> blockId, PRINCIPAL/TEACHER/STUDENT -> schoolId.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String
  tenantId     String?
  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  districtId   String?
  district     District? @relation(fields: [districtId], references: [id])
  blockId      String?
  block        Block?    @relation(fields: [blockId], references: [id])
  schoolId     String?
  school       School?   @relation(fields: [schoolId], references: [id])
  studentId         String?   // for STUDENT role: links to Student.id
  linkedStudentIds  String?   // for PARENT role: comma-separated Student ids
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
}

// ── Attendance ───────────────────────────────────────────────────────────────

// status: "P" present | "A" absent | "L" late | "HD" half-day
model Attendance {
  id          String   @id @default(cuid())
  studentId   String
  schoolId    String
  date        String   // "YYYY-MM-DD"
  status      String   @default("P")
  markedBy    String?  // userId of teacher/admin who marked
  academicYear String

  @@unique([studentId, date])
  @@index([schoolId, date])
  @@index([studentId])
}

// status: "P" present | "A" absent | "L" late | "OD" on-duty
model StaffAttendance {
  id          String   @id @default(cuid())
  staffId     String
  schoolId    String
  date        String   // "YYYY-MM-DD"
  status      String   @default("P")
  markedBy    String?
  academicYear String

  @@unique([staffId, date])
  @@index([schoolId, date])
}

// ── Exam Results / Report Card ───────────────────────────────────────────────

// examType: "FA1" | "FA2" | "SA1" | "SA2" | "ANNUAL" | "BOARD"
model ExamResult {
  id           String @id @default(cuid())
  studentId    String
  schoolId     String
  subject      String
  grade        Int    // class 1..12
  section      String? // A | B | ...
  examType     String
  academicYear String
  marksObtained Float
  maxMarks      Float  @default(100)
  grade_letter  String? // A+ | A | B+ | B | C | D | F
  remarks       String?

  @@unique([studentId, subject, examType, academicYear])
  @@index([schoolId, grade, academicYear])
}

// ── Holidays ──────────────────────────────────────────────────────────────────

// scope: "SCHOOL" | "BLOCK" | "DISTRICT" | "TENANT"
model Holiday {
  id            String   @id @default(cuid())
  title         String
  description   String?
  startDate     String   // "YYYY-MM-DD"
  endDate       String   // "YYYY-MM-DD" (same as startDate for single day)
  scope         String   // "SCHOOL" | "BLOCK" | "DISTRICT" | "TENANT"
  scopeId       String   // schoolId / blockId / districtId / tenantId
  createdBy     String   // userId
  createdByName String?
  createdAt     DateTime @default(now())

  @@index([scopeId, startDate])
  @@index([scope, scopeId])
}

// ── Events (live school/state events — replaces static EVENTS array) ──────────

// type: "Ceremony" | "Workshop" | "Assessment" | "Meeting" | "Exam" | "Other"
// scope / scopeId reuse the same pattern as Holiday
model Event {
  id            String   @id @default(cuid())
  title         String
  description   String?
  type          String   @default("Other")
  date          String   // "YYYY-MM-DD"
  endDate       String?  // optional multi-day
  urgent        Boolean  @default(false)
  scope         String   // "SCHOOL" | "BLOCK" | "DISTRICT" | "TENANT"
  scopeId       String
  createdBy     String   // userId
  createdByName String?
  createdAt     DateTime @default(now())

  @@index([scopeId, date])
  @@index([scope, scopeId])
}

// ── Leave Requests ────────────────────────────────────────────────────────────

// status: "PENDING" | "APPROVED" | "REJECTED"
// reason: "SICK" | "FAMILY" | "MEDICAL" | "PERSONAL" | "OTHER"
model LeaveRequest {
  id              String    @id @default(cuid())
  studentId       String
  studentName     String?
  schoolId        String
  startDate       String    // "YYYY-MM-DD"
  endDate         String    // "YYYY-MM-DD"
  reason          String    // "SICK" | "FAMILY" | "MEDICAL" | "PERSONAL" | "OTHER"
  remarks         String?   // student's note
  status          String    @default("PENDING")
  approvedBy      String?   // userId of approver
  approvedByName  String?
  approvedAt      DateTime?
  approverRemarks String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([studentId])
  @@index([schoolId, status])
}

// ── Notice Board ─────────────────────────────────────────────────────────────

// type: "General" | "Academic" | "Event" | "Urgent"
// scope: "school" | "block" | "district" | "all" — who this notice is visible to
model Notice {
  id            String   @id @default(cuid())
  scope         String   @default("school") // school | block | district | all
  schoolId      String?  // set when scope = "school"
  school        School?  @relation(fields: [schoolId], references: [id])
  blockId       String?  // set when scope = "block"
  districtId    String?  // set when scope = "district"
  tenantId      String?  // set when scope = "all"
  title         String
  description   String?
  type          String   @default("General")
  publishDate   String   // "YYYY-MM-DD"
  expiryDate    String?  // optional "YYYY-MM-DD"
  createdById   String   // userId
  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([schoolId, publishDate])
  @@index([blockId, publishDate])
  @@index([districtId, publishDate])
  @@index([tenantId, publishDate])
}

// ── Academic Year ─────────────────────────────────────────────────────────────

model AcademicYear {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  label     String   // "2025-26"
  startDate String   // "YYYY-MM-DD"
  endDate   String   // "YYYY-MM-DD"
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([tenantId, label])
  @@index([tenantId, isCurrent])
}

// ── Class & Section Structure ─────────────────────────────────────────────────

model ClassSection {
  id             String   @id @default(cuid())
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id])
  academicYear   String   // "2025-26"
  grade          Int      // 1..12
  section        String   // "A" | "B" | ...
  classTeacherId String?  // Staff.id (optional)
  capacity       Int?
  stream         String?  // "Science" | "Arts" | "Commerce" (grades 11-12)
  createdAt      DateTime @default(now())

  subjectAssignments SubjectAssignment[]

  @@unique([schoolId, academicYear, grade, section])
  @@index([schoolId, academicYear])
}

// ── Subject Master ────────────────────────────────────────────────────────────

model Subject {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  code      String?  // e.g. "MATH", "ENG"
  name      String   // e.g. "Mathematics"
  grade     Int?     // null = applicable to all grades
  stream    String?  // "Science" | "Arts" | "Commerce" | null for all
  maxMarks  Float    @default(100)
  isElective Boolean @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  subjectAssignments SubjectAssignment[]

  @@unique([tenantId, name, grade])
  @@index([tenantId, isActive])
}

// ── Subject Assignment (teacher → class → subject) ───────────────────────────

model SubjectAssignment {
  id             String   @id @default(cuid())
  staffId        String   // Staff.id
  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear   String
  createdAt      DateTime @default(now())

  @@unique([staffId, classSectionId, subjectId, academicYear])
  @@index([classSectionId])
  @@index([staffId])
}

// ── Quiz Engine ──────────────────────────────────────────────────────────────

// A quiz/test created by a teacher or principal for a class.
// isActive: false means it's archived. dueDate "YYYY-MM-DD" when submissions close.
// scope: "school" | "block" | "district" | "all" — controls which schools see this quiz.
model Quiz {
  id           String         @id @default(cuid())
  schoolId     String?        // null when scope != "school"
  school       School?        @relation(fields: [schoolId], references: [id])
  scope        String         @default("school") // school | block | district | all
  blockId      String?        // populated when scope = "block"
  districtId   String?        // populated when scope = "district"
  tenantId     String?        // populated when scope = "all" (entire state)
  title        String
  description  String?
  subject      String
  grade        Int
  section      String?
  academicYear String
  dueDate      String?
  isActive     Boolean        @default(true)
  createdBy    String?        // userId of creator
  createdAt    DateTime       @default(now())
  questions    QuizQuestion[]
  attempts     StudentAttempt[]

  @@index([schoolId, grade, academicYear])
  @@index([tenantId, grade, academicYear])
  @@index([districtId, grade, academicYear])
  @@index([blockId, grade, academicYear])
}

// One MCQ question inside a quiz.
// options is JSON-encoded string: ["Option A","Option B","Option C","Option D"]
// correct is 0-based index into options.
model QuizQuestion {
  id          String  @id @default(cuid())
  quizId      String
  quiz        Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question    String
  options     String // JSON array of 2–4 option strings
  correct     Int
  marks       Float   @default(1)
  orderNo     Int     @default(0)
  explanation String? // short rationale shown in answer review (optional)
}

// A student's completed attempt at a quiz.
// answers is JSON: { "<questionId>": <selectedIndex 0-3> }
model StudentAttempt {
  id          String   @id @default(cuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  studentId   String
  answers     String   // JSON map questionId→selectedIndex
  score       Float
  maxScore    Float
  timeTaken   Int?     // seconds
  completedAt DateTime @default(now())

  @@unique([quizId, studentId])
  @@index([studentId])
}

// ── Content / Virtual Classroom recordings ───────────────────────────────────

// One row per live-broadcast session imported from the Lecture data Excel.
// studioName: "Studio1" | "Studio2" | "Studio3" | "Studio4"
// medium: "Hindi" | "English"
model Lecture {
  id          String  @id @default(cuid())
  srNo        Int
  date        String  // "YYYY-MM-DD"
  studioName  String  // Studio1..4
  medium      String  @default("Hindi")
  startTime   String
  endTime     String
  standard    Int     // 6..12
  teacherName String
  subject     String
  topic       String
  youtubeUrl  String? // exact video URL once linked

  @@index([standard, subject])
  @@index([studioName, date])
  @@index([standard, subject, studioName])
}

// Studio → YouTube channel mapping (one row per studio).
model ContentChannel {
  id          String @id @default(cuid())
  studioName  String @unique
  channelName String
  channelUrl  String
}
